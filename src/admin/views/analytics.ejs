    if (['discover_load', 'swipe', 'undo_swipe', 'get_matches_list', 'unmatch'].includes(step)) return '#f59e0b';
    if (['quiz_start', 'quiz_answer', 'quiz_rescue', 'quiz_fail', 'quiz_result', 'quiz_summary', 'get_current_question'].includes(step)) return '#10b981';
    if (['get_messages', 'send_message', 'upload_chat_media', 'mark_chat_read', 'add_reaction', 'delete_message'].includes(step)) return '#8b5cf6';
    if (['create_question', 'get_my_questions', 'update_question', 'delete_question', 'get_question_analytics', 'ai_suggest_questions', 'create_chat_question', 'answer_chat_question'].includes(step)) return '#ec4899';
    if (['purchase_diamonds', 'get_diamond_balance', 'exchange_convert', 'buy_power', 'get_powers', 'get_subscription_status', 'activate_subscription'].includes(step)) return '#f97316';
    if (['get_profile', 'update_profile', 'upload_photo', 'complete_profile', 'update_details', 'boost_profile', 'view_public_profile'].includes(step)) return '#06b6d4';
    if (['passport_activate', 'passport_deactivate'].includes(step)) return '#84cc16';
    if (['get_notifications', 'notification_click', 'mark_notification_read'].includes(step)) return '#14b8a6';
    return '#6b7280';
  }

  function getCategoryColorByName(cat) {
    var colors = {
      auth: '#3b82f6',
      matching: '#f59e0b',
      chat: '#8b5cf6',
      questions: '#ec4899',
      economy: '#f97316',
      profile: '#06b6d4',
      passport: '#84cc16',
      notifications: '#14b8a6',
      moderation: '#ef4444',
