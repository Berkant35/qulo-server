<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
function changeDays(val) {
  // Clean URL, no nocache — use cached results when available
  window.location.href = '/admin/analytics?days=' + encodeURIComponent(val);
}

function refreshData() {
  // Force bypass cache for fresh data
  var url = new URL(window.location.href);
  url.searchParams.set('nocache', '1');
  window.location.href = url.toString();
}

// Custom Funnel Builder
function runCustomFunnel() {
  var from = document.getElementById('funnelFrom').value;
  var to = document.getElementById('funnelTo').value;
  var window = document.getElementById('funnelWindow').value;
  var errorEl = document.getElementById('funnelError');
  var resultEl = document.getElementById('funnelResult');

  errorEl.style.display = 'none';
  resultEl.style.display = 'none';

  if (!from || !to) {
    errorEl.textContent = 'Select both from and to events.';
    errorEl.style.display = 'block';
    return;
  }
  if (from === to) {
    errorEl.textContent = 'From and to events must be different.';
    errorEl.style.display = 'block';
    return;
  }

  var days = document.getElementById('daysFilter').value;
  var url = '/admin/analytics/api?section=custom-funnel'
    + '&from=' + encodeURIComponent(from)
    + '&to=' + encodeURIComponent(to)
    + '&window=' + encodeURIComponent(window)
    + '&days=' + encodeURIComponent(days);

  fetch(url)
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!res.ok) {
        errorEl.textContent = res.error || 'Error computing funnel.';
        errorEl.style.display = 'block';
        return;
      }
      var d = res.data;
      document.getElementById('funnelFromUsers').textContent = d.from_users;
      document.getElementById('funnelToUsers').textContent = d.to_users;
      document.getElementById('funnelRate').textContent = d.conversion_rate + '%';

      function fmtTime(sec) {
        if (!sec || sec === 0) return '-';
        if (sec < 60) return Math.round(sec) + 's';
        if (sec < 3600) return Math.round(sec / 60) + 'm';
        if (sec < 86400) return (sec / 3600).toFixed(1) + 'h';
        return (sec / 86400).toFixed(1) + 'd';
      }
      document.getElementById('funnelAvgTime').textContent = fmtTime(d.avg_time_seconds);
      document.getElementById('funnelMedianTime').textContent = fmtTime(d.median_time_seconds);

      // Color based on rate
      var rate = d.conversion_rate;
      var rateEl = document.getElementById('funnelRate');
      rateEl.style.color = rate > 50 ? '#22c55e' : rate > 20 ? '#f59e0b' : rate > 5 ? '#a855f7' : '#ef4444';

      resultEl.style.display = 'block';
    })
    .catch(function() {
      errorEl.textContent = 'Network error.';
      errorEl.style.display = 'block';
    });
}

// Auto-refresh
var autoRefreshTimer = null;
function toggleAutoRefresh(enabled) {
  if (enabled) {
    autoRefreshTimer = setInterval(function() { window.location.reload(); }, 30000);
  } else {
    if (autoRefreshTimer) clearInterval(autoRefreshTimer);
    autoRefreshTimer = null;
  }
}

// Event delegation for user journey links (safer than inline onclick)
document.addEventListener('click', function(e) {
  var el = e.target.closest('.user-journey-link');
  if (el) {
    e.preventDefault();
    var uid = el.getAttribute('data-user-id');
    if (uid) lookupUser(uid);
  }
});

// User Journey Lookup — uses safe DOM methods (no innerHTML)
function lookupUser(userId) {
  if (!userId || userId.length < 8) return;
  document.getElementById('journeyUserId').value = userId;
  document.getElementById('journeyResults').style.display = 'none';
  document.getElementById('journeyEmpty').style.display = 'none';

  fetch('/admin/analytics/api?section=user-journey&userId=' + encodeURIComponent(userId))
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!res.ok || !res.data || res.data.length === 0) {
        document.getElementById('journeyEmpty').style.display = 'block';
        return;
      }
      var tbody = document.getElementById('journeyBody');
      while (tbody.firstChild) tbody.removeChild(tbody.firstChild);

      res.data.forEach(function(e) {
        var tr = document.createElement('tr');

        var tdTime = document.createElement('td');
        tdTime.style.cssText = 'font-size:11px;color:#666;white-space:nowrap';
        tdTime.textContent = new Date(e.created_at).toLocaleString('tr-TR');
        tr.appendChild(tdTime);

        var tdAction = document.createElement('td');
        var code = document.createElement('code');
        code.style.fontSize = '11px';
        code.textContent = e.event_name;
        tdAction.appendChild(code);
        tr.appendChild(tdAction);

        var tdCat = document.createElement('td');
        var catSpan = document.createElement('span');
        catSpan.style.cssText = 'font-size:10px;color:#666';
        catSpan.textContent = e.category;
        tdCat.appendChild(catSpan);
        tr.appendChild(tdCat);

        var tdStatus = document.createElement('td');
        tdStatus.style.fontSize = '11px';
        tdStatus.style.color = e.status_code < 300 ? '#22c55e' : e.status_code < 400 ? '#f59e0b' : '#ef4444';
        tdStatus.textContent = String(e.status_code);
        tr.appendChild(tdStatus);

        var tdSpeed = document.createElement('td');
        tdSpeed.style.fontSize = '11px';
        tdSpeed.style.color = e.response_time_ms > 500 ? '#ef4444' : e.response_time_ms > 200 ? '#f59e0b' : '#22c55e';
        tdSpeed.textContent = e.response_time_ms + 'ms';
        tr.appendChild(tdSpeed);

        tbody.appendChild(tr);
      });
      document.getElementById('journeyResults').style.display = 'block';

      // Also load session timeline
      loadSessionTimeline(userId);
    })
    .catch(function() {
      document.getElementById('journeyEmpty').style.display = 'block';
    });
}

function loadSessionTimeline(userId) {
  var container = document.getElementById('sessionContent');
  var wrapper = document.getElementById('sessionTimeline');
  wrapper.style.display = 'none';
  while (container.firstChild) container.removeChild(container.firstChild);

  fetch('/admin/analytics/api?section=user-sessions&userId=' + encodeURIComponent(userId))
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!res.ok || !res.data || res.data.length === 0) return;

      var catColors = {
        auth: '#3b82f6', matching: '#f59e0b', chat: '#8b5cf6', questions: '#ec4899',
        economy: '#f97316', profile: '#06b6d4', passport: '#84cc16', notifications: '#14b8a6',
        moderation: '#ef4444', referral: '#a855f7', other: '#6b7280'
      };

      res.data.forEach(function(session) {
        var sessionDiv = document.createElement('div');
        sessionDiv.style.cssText = 'margin-bottom: 12px; padding: 10px; background: #fafafa; border-radius: 6px; border-left: 3px solid #a855f7;';

        var header = document.createElement('div');
        header.style.cssText = 'display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 12px;';

        var left = document.createElement('span');
        left.style.fontWeight = '600';
        left.textContent = 'Session #' + session.session_num + ' (' + session.event_count + ' events)';
        header.appendChild(left);

        var right = document.createElement('span');
        right.style.color = '#666';
        var mins = Math.round(session.duration_seconds / 60);
        right.textContent = new Date(session.session_start).toLocaleString('tr-TR') + ' | ' + (mins > 0 ? mins + 'min' : session.duration_seconds + 's');
        header.appendChild(right);

        sessionDiv.appendChild(header);

        // Event dots timeline
        var timeline = document.createElement('div');
        timeline.style.cssText = 'display: flex; flex-wrap: wrap; gap: 3px;';

        session.events.forEach(function(evt) {
          var dot = document.createElement('span');
          var color = catColors[evt.category] || '#6b7280';
          dot.style.cssText = 'display: inline-block; padding: 2px 6px; border-radius: 3px; font-size: 10px; background: ' + color + '20; color: ' + color + ';';
          dot.textContent = evt.name;
          dot.title = evt.category + ' | ' + evt.status + ' | ' + evt.ms + 'ms | ' + new Date(evt.at).toLocaleTimeString('tr-TR');
          timeline.appendChild(dot);
        });

        sessionDiv.appendChild(timeline);
        container.appendChild(sessionDiv);
      });

      wrapper.style.display = 'block';
    })
    .catch(function() {});
}

// Chart.js defaults
Chart.defaults.font.family = "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
Chart.defaults.font.size = 12;

// DAU Trend Chart
(function() {
  var data = <%- JSON.stringify(dauTimeseries) %>;
