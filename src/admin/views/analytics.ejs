          tension: 0.3,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: { beginAtZero: true },
        x: { display: true, ticks: { maxTicksLimit: 10 } }
      },
      plugins: { legend: { position: 'top' } }
    }
  });
})();

// Hourly Activity Chart
(function() {
  var data = <%- JSON.stringify(hourly) %>;
  if (data.length === 0) return;

  new Chart(document.getElementById('hourlyChart'), {
    type: 'bar',
    data: {
      labels: data.map(function(d) { return d.hour + ':00'; }),
      datasets: [{
        label: 'Events',
        data: data.map(function(d) { return d.count; }),
        backgroundColor: data.map(function(d) {
          return d.hour >= 9 && d.hour <= 23 ? 'rgba(168, 85, 247, 0.7)' : 'rgba(168, 85, 247, 0.3)';
        }),
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: { beginAtZero: true },
        x: { ticks: { maxTicksLimit: 12 } }
      },
      plugins: { legend: { display: false } }
    }
  });
})();

// Conversion Funnel Chart
(function() {
  var data = <%- JSON.stringify(funnel) %>;
  if (data.length === 0) return;

  var colors = ['#3b82f6', '#06b6d4', '#f59e0b', '#f97316', '#10b981', '#8b5cf6', '#ec4899', '#a855f7'];

  new Chart(document.getElementById('funnelChart'), {
    type: 'bar',
    data: {
      labels: data.map(function(d) { return d.label + ' (' + d.percentage + '%)'; }),
      datasets: [{
        label: 'Users',
        data: data.map(function(d) { return d.count; }),
        backgroundColor: colors.slice(0, data.length),
        borderRadius: 4,
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      scales: { x: { beginAtZero: true } },
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(ctx) {
              return ctx.parsed.x + ' users (' + data[ctx.dataIndex].percentage + '%)';
            }
          }
        }
      }
    }
  });
})();

// Category Breakdown Doughnut
(function() {
  var data = <%- JSON.stringify(categoryBreakdown) %>;
  if (data.length === 0) return;

  var colors = {
    auth: '#3b82f6', matching: '#f59e0b', chat: '#8b5cf6', questions: '#ec4899',
    economy: '#f97316', profile: '#06b6d4', passport: '#84cc16', notifications: '#14b8a6',
    moderation: '#ef4444', referral: '#a855f7', support: '#6366f1', webhook: '#78716c',
    app: '#6b7280', other: '#9ca3af',
  };

  new Chart(document.getElementById('categoryChart'), {
    type: 'doughnut',
    data: {
      labels: data.map(function(d) { return d.category; }),
      datasets: [{
        data: data.map(function(d) { return d.count; }),
        backgroundColor: data.map(function(d) { return colors[d.category] || '#9ca3af'; }),
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'right', labels: { padding: 12, font: { size: 11 } } },
        tooltip: {
          callbacks: {
            label: function(ctx) {
              return ctx.label + ': ' + ctx.parsed + ' (' + data[ctx.dataIndex].percentage + '%)';
            }
          }
        }
      }
    }
  });
})();
</script>

