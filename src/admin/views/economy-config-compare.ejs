<%- include('_header') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h2>Economy Config — Compare Versions</h2>
  <a href="/admin/economy-config/history" class="btn btn-primary">Back to History</a>
</div>

<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<% if (diff) { %>
<div class="card" style="margin-bottom: 16px;">
  <div style="display: flex; gap: 24px; font-size: 14px;">
    <div><strong>Old:</strong> v<%= diff.v1 %> <% if (v1Data && v1Data.changed_by) { %>(by <%= v1Data.changed_by %>)<% } %></div>
    <div><strong>New:</strong> v<%= diff.v2 %> <% if (v2Data && v2Data.changed_by) { %>(by <%= v2Data.changed_by %>)<% } %></div>
  </div>
  <% if (v2Data && v2Data.change_reason) { %>
  <p style="margin-top: 8px; font-size: 13px; color: #666;"><strong>Reason:</strong> <%= v2Data.change_reason %></p>
  <% } %>
</div>

<% if (diff.changes.length === 0) { %>
<div class="card">
  <p style="color: #999; text-align: center;">No differences found between v<%= diff.v1 %> and v<%= diff.v2 %>.</p>
</div>
<% } else { %>
<div class="card">
  <h3 style="margin-bottom: 12px;"><%= diff.changes.length %> change<%= diff.changes.length > 1 ? 's' : '' %> found</h3>
  <table>
    <thead>
      <tr>
        <th>Path</th>
        <th>Old Value (v<%= diff.v1 %>)</th>
        <th>New Value (v<%= diff.v2 %>)</th>
      </tr>
    </thead>
    <tbody>
      <% diff.changes.forEach((c) => { %>
      <tr>
        <td style="font-family:monospace; font-size:13px;"><%= c.path %></td>
        <td style="background: #fef2f2; color: #991b1b; font-family:monospace; font-size:13px;"><%= c.oldValue !== undefined ? JSON.stringify(c.oldValue) : '—' %></td>
        <td style="background: #f0fdf4; color: #166534; font-family:monospace; font-size:13px;"><%= c.newValue !== undefined ? JSON.stringify(c.newValue) : '—' %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>
<% } %>

<%- include('_footer') %>
